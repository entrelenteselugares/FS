{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/raw-debug",
      "destination": "/api/debug"
    },
    {
      "source": "/api/edge/(.*)",
      "destination": "/api/edge"
    },
    {
      "source": "/api/auth/(.*)",
      "destination": "/api/auth"
    },
    {
      "source": "/api/profissional/me",
      "destination": "/api/profissional-hono"
    },
    {
      "source": "/api/profissional/events",
      "destination": "/api/profissional-hono"
    },
    {
      "source": "/api/checkout/(.*)",
      "destination": "/api/checkout"
    },
    {
      "source": "/api/public/events",
      "destination": "/api/public-hono"
    },
    {
      "source": "/api/public/events/cities",
      "destination": "/api/public-hono"
    },
    {
      "source": "/api/public/banners",
      "destination": "/api/public-hono"
    },
    {
      "source": "/api/worldcup/(.*)",
      "destination": "/api/core"
    },
    {
      "source": "/api/public/(.*)",
      "destination": "/api/events"
    },
    {
      "source": "/api/flash/(.*)",
      "destination": "/api/events"
    },
    {
      "source": "/api/vaults/(.*)",
      "destination": "/api/events"
    },
    {
      "source": "/api/profissional/(.*)",
      "destination": "/api/events"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/core"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
