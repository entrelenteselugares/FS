// ─────────────────────────────────────────────────────────────────────────────
// Foto Segundo — Prisma Schema v2.0
// Gerado e validado pela auditoria estática de 2026-04-17
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  CARTORIO
  PROFISSIONAL
  CLIENTE
}

enum OrderStatus {
  PENDENTE
  APROVADO
  RECUSADO
  ESTORNADO
}

// ─── Model: User ─────────────────────────────────────────────────────────────
// Usado para: Admin, Cartório, Profissional (Fotógrafo/Editor), Cliente

model User {
  id       String @id @default(cuid())
  email    String @unique
  senha    String
  nome     String
  role     Role   @default(CLIENTE)
  whatsapp String?

  // ── Credenciais OAuth Mercado Pago ────────────────────────────────────────
  // Preenchidas quando o profissional conecta sua conta via /api/mercadopago/connect
  mpAccessToken  String?
  mpPublicKey    String?
  mpRefreshToken String?
  mpUserId       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relações ──────────────────────────────────────────────────────────────
  eventosComoFotografo Event[] @relation("Fotografo")
  eventosComoEditor    Event[] @relation("Editor")
  eventosComoCartorio  Event[] @relation("CartorioUser")

  @@map("fs_users")
}

// ─── Model: Event ────────────────────────────────────────────────────────────
// Um evento de casamento. Criado pelo Admin/Profissional.

model Event {
  id        String   @id @default(cuid())
  nomeNoivos String
  dataEvento DateTime
  cartorio   String?
  temFoto         Boolean @default(false)
  temFotoImpressa Boolean @default(false)

  // ── URLs de Entrega (liberadas após pagamento aprovado) ───────────────────
  lightroomUrl  String? // URL do álbum Adobe Lightroom (fotos)
  driveUrl      String? // URL da pasta Google Drive (vídeos)
  coverPhotoUrl String? // URL da foto de capa (imagem do evento)

  // ── Equipe do Evento (parceiros que recebem split) ────────────────────────
  fotografoId    String?
  editorId       String?
  cartorioUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relações ──────────────────────────────────────────────────────────────
  fotografo    User? @relation("Fotografo", fields: [fotografoId], references: [id])
  editor       User? @relation("Editor", fields: [editorId], references: [id])
  cartorioUser User? @relation("CartorioUser", fields: [cartorioUserId], references: [id])
  pedidos      Order[]
  midias       MediaFile[]

  @@map("fs_events")
}

model MediaFile {
  id           String  @id @default(cuid())
  url          String
  tipo         String  @default("FOTO")
  isCoverPhoto Boolean @default(false)
  eventId      String
  event        Event   @relation(fields: [eventId], references: [id])

  @@map("fs_media_files")
}

// ─── Model: Order ────────────────────────────────────────────────────────────
// Representa uma tentativa de compra de acesso a um evento.
// clienteId é um ID temporário (localStorage) — NOT a FK para User,
// pois o cliente pode ser não-autenticado no momento da compra.

model Order {
  id        String      @id @default(cuid())
  eventId   String
  clienteId String      // ID temporário do comprador (localStorage UUID)
  valor     Decimal     @db.Decimal(10, 2)
  status    OrderStatus @default(PENDENTE)
  paymentId String?     // ID do pagamento no Mercado Pago

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relações ──────────────────────────────────────────────────────────────
  event Event @relation(fields: [eventId], references: [id])

  @@map("fs_orders")
}
