generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String                  @id @default(cuid())
  email              String                  @unique
  senha              String
  nome               String
  role               Role                    @default(CLIENTE)
  whatsapp           String?
  active             Boolean                 @default(true)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  mpUserId           String?
  mpAccessToken      String?
  mpPublicKey        String?
  mpRefreshToken     String?
  pixKey             String?
  acceptedPrivacyAt  DateTime?
  acceptedTermsAt    DateTime?
  resetToken         String?
  resetTokenExpires  DateTime?
  isVerified         Boolean                 @default(false)
  verificationDocs   Json?
  verificationStatus String                  @default("PENDING")
  referralCode       String?                 @unique
  rewardCredits      Decimal                 @default(0) @db.Decimal(10, 2)
  calendarSlots      CalendarSlot[]
  cartorio           Cartorio?
  eventsCaptacao     Event[]                 @relation("CaptacaoEvents")
  eventsCartorio     Event[]                 @relation("CartorioUserEvents")
  eventsEdicao       Event[]                 @relation("EdicaoEvents")
  franchiseProfile   FranchiseProfile?
  gamificationLogs   GamificationLedger[]
  pedidos            Order[]                 @relation("ClienteOrders")
  ordersToEdit       Order[]                 @relation("EditorOrders")
  passiveCommissions Order[]                 @relation("FranchiseePassiveCommissions")
  likes              PhotoLike[]
  redemptions        PrintRedemption[]
  favoritedBy        ProfessionalNetwork[]   @relation("FavoritedBy")
  favorites          ProfessionalNetwork[]   @relation("UserFavorites")
  profissional       Profissional?
  calendarCredential UserCalendarCredential?
  points             UserPoints?
  ownedAlbums        SharedAlbum[]           @relation("OwnedAlbums")
  albumMemberships   AlbumMember[]
  sharedAlbumMedia   SharedAlbumMedia[]
  mediaVotes         MediaVote[]
  subscriptions      Subscription[]

  @@map("users")
}

model GamificationLedger {
  id          String   @id @default(cuid())
  userId      String
  type        String
  points      Int      @default(0)
  amount      Decimal? @db.Decimal(10, 2)
  description String?
  orderId     String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@map("gamification_ledger")
}

model ProfessionalNetwork {
  id        String   @id @default(cuid())
  userId    String
  partnerId String
  createdAt DateTime @default(now())
  partner   User     @relation("FavoritedBy", fields: [partnerId], references: [id], onDelete: Cascade)
  user      User     @relation("UserFavorites", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, partnerId])
  @@map("professional_networks")
}

model Event {
  id                 String              @id @default(cuid())
  nomeNoivos         String
  dataEvento         DateTime
  cartorio           String?
  coverPhotoUrl      String?
  lightroomUrl       String?
  driveUrl           String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  cartorioUserId     String?
  priceBase          Decimal             @default(190) @db.Decimal(10, 2)
  priceEarly         Decimal             @default(190) @db.Decimal(10, 2)
  captacaoId         String?
  edicaoId           String?
  active             Boolean             @default(false)
  city               String?
  description        String?
  location           String?
  slug               String?             @unique
  temFoto            Boolean             @default(true)
  temFotoImpressa    Boolean             @default(false)
  temReels           Boolean             @default(false)
  temVideo           Boolean             @default(false)
  priceAlbum         Decimal?            @db.Decimal(10, 2)
  priceFoto          Decimal?            @db.Decimal(10, 2)
  priceFotoEditada   Decimal?            @db.Decimal(10, 2)
  priceReels         Decimal?            @db.Decimal(10, 2)
  priceVideo         Decimal?            @db.Decimal(10, 2)
  priceVideoEditado  Decimal?            @db.Decimal(10, 2)
  temAlbumImpresso   Boolean             @default(false)
  temFotoEditada     Boolean             @default(false)
  temVideoEditado    Boolean             @default(false)
  eventHours         Int?                @default(2)
  eventDays          Int?                @default(1)
  collectedAmount    Decimal             @default(0) @db.Decimal(10, 2)
  isCrowdfund        Boolean             @default(false)
  targetAmount       Decimal?            @db.Decimal(10, 2)
  clientEmail        String?
  clientName         String?
  isQuote            Boolean             @default(false)
  quoteStatus        QuoteStatus?
  usageType          String?
  captacaoStatus     AcceptanceStatus    @default(PENDING)
  edicaoStatus       AcceptanceStatus    @default(PENDING)
  previewPhotos      String?
  isPrivate          Boolean             @default(false)
  isPublicCall       Boolean             @default(false)
  isUnitSale         Boolean             @default(false)
  priceUnit          Decimal             @default(10) @db.Decimal(10, 2)
  type               EventType           @default(ALBUM_FULL)
  pricePerPhoto      Decimal?            @db.Decimal(10, 2)
  marketplaceConfigs Json?               @default("{}")
  rejectedBy         Json?               @default("[]")
  ownerId            String?
  franchiseeId       String?
  deliveryType       DeliveryType        @default(DIGITAL_ONLY)
  paymentModel       PaymentModel        @default(PRE_PAID)
  eventEndTime       DateTime?
  galleryUploadTime  DateTime?
  itinerary          String?
  references         Json?               @default("[]")
  calendarSlots      CalendarSlot[]
  media              EventMedia[]
  captacao           User?               @relation("CaptacaoEvents", fields: [captacaoId], references: [id])
  cartorioUser       User?               @relation("CartorioUserEvents", fields: [cartorioUserId], references: [id])
  edicao             User?               @relation("EdicaoEvents", fields: [edicaoId], references: [id])
  franchisee         FranchiseProfile?   @relation(fields: [franchiseeId], references: [id])
  pedidos            Order[]
  likes              PhotoLike[]
  phygitalPrints     PhygitalPrint[]
  retentionDays      Int?                @default(15)
  printProducts      EventPrintProduct[]

  @@map("events")
}

model PhygitalPrint {
  id                 String            @id @default(cuid())
  referenceCode      String            @unique
  imageUrl           String
  customerName       String
  customerPhone      String
  customerCep        String
  eventId            String
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  franchiseProfileId String?
  status             PrintStatus       @default(PENDING_PRINT)
  event              Event             @relation(fields: [eventId], references: [id])
  franchiseProfile   FranchiseProfile? @relation(fields: [franchiseProfileId], references: [id])

  @@map("phygital_prints")
}

model Profissional {
  id                    String                 @id @default(cuid())
  userId                String                 @unique
  services              String[]
  cameras               String[]
  lenses                String[]
  lighting              String[]
  captPct               Float                  @default(30)
  editPct               Float                  @default(20)
  otherHabilities       String?
  equipment             String?
  equipmentMultiplier   Float                  @default(1.0)
  hourlyRate            Decimal                @default(60.00) @db.Decimal(10, 2)
  equipmentList         Json?                  @default("[]")
  experienceYears       Int                    @default(0)
  workflowType          String[]               @default(["TRADICIONAL"])
  firstJobUrl           String?
  isExperienceValidated Boolean                @default(false)
  agilityPoints         Int                    @default(0)
  avgDeliveryHours      Float                  @default(0)
  totalMissions         Int                    @default(0)
  cartorios             CartorioProfissional[]
  proServices           ProfessionalService[]
  user                  User                   @relation(fields: [userId], references: [id])

  @@map("profissionais")
}

model Cartorio {
  id               String                 @id @default(cuid())
  userId           String                 @unique
  razaoSocial      String
  cnpj             String?                @unique
  splitPct         Float                  @default(10)
  address          String?
  coverUrl         String?
  description      String?
  phone            String?
  slug             String?                @unique
  cidade           String?
  priceFoto        Decimal?               @db.Decimal(10, 2)
  priceImpresso    Decimal?               @db.Decimal(10, 2)
  priceReels       Decimal?               @db.Decimal(10, 2)
  priceVideo       Decimal?               @db.Decimal(10, 2)
  servicePrices    Json?
  fixedDuration    Int?                   @default(2)
  fixedTime        Boolean                @default(false)
  hideDuration     Boolean                @default(false)
  disabledServices String[]               @default([])
  workingHours     Json?                  @default("{\"fri\": {\"open\": \"09:00\", \"close\": \"18:00\", \"closed\": false}, \"mon\": {\"open\": \"09:00\", \"close\": \"18:00\", \"closed\": false}, \"sat\": {\"open\": \"09:00\", \"close\": \"12:00\", \"closed\": true}, \"sun\": {\"open\": \"00:00\", \"close\": \"00:00\", \"closed\": true}, \"thu\": {\"open\": \"09:00\", \"close\": \"18:00\", \"closed\": false}, \"tue\": {\"open\": \"09:00\", \"close\": \"18:00\", \"closed\": false}, \"wed\": {\"open\": \"09:00\", \"close\": \"18:00\", \"closed\": false}}")
  services         String[]               @default([])
  profissionais    CartorioProfissional[]
  user             User                   @relation(fields: [userId], references: [id])
  quotes           Quote[]

  @@map("cartorios")
}

model CartorioProfissional {
  id             String       @id @default(cuid())
  cartorioId     String
  profissionalId String
  tipo           String       @default("FIXO")
  status         String       @default("PENDING")
  createdAt      DateTime     @default(now())
  cartorio       Cartorio     @relation(fields: [cartorioId], references: [id], onDelete: Cascade)
  profissional   Profissional @relation(fields: [profissionalId], references: [id], onDelete: Cascade)

  @@unique([cartorioId, profissionalId])
  @@map("cartorio_profissionais")
}

model Order {
  id                  String              @id @default(cuid())
  valor               Decimal             @db.Decimal(10, 2)
  status              String              @default("PENDENTE")
  paymentId           String?             @unique
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  clienteId           String?
  eventId             String
  buyerEmail          String?
  splitCaptacao       Decimal?            @db.Decimal(10, 2)
  splitCartorio       Decimal?            @db.Decimal(10, 2)
  splitEdicao         Decimal?            @db.Decimal(10, 2)
  splitMatriz         Decimal?            @db.Decimal(10, 2)
  accessChosenAt      DateTime?
  accessExpiresAt     DateTime?
  accessType          String?
  deletedAt           DateTime?
  warningsSent        Int                 @default(0)
  contributorName     String?
  isContribution      Boolean             @default(false)
  hasPaid             Boolean             @default(false)
  tempPassword        String?
  showAlbum           Boolean             @default(true)
  showVideo           Boolean             @default(true)
  isManual            Boolean             @default(false)
  manualType          String?
  buyerWhatsapp       String?
  internalNotes       String?
  editorId            String?
  deliveryType        DeliveryType        @default(DIGITAL_ONLY)
  guestEmail          String?
  guestPhone          String?
  guestToken          String?             @unique
  isGuestOrder        Boolean             @default(false)
  paymentMethod       OrderPaymentMethod?
  paymentModel        PaymentModel        @default(PRE_PAID)
  shippingAddress     Json?
  shippingFee         Decimal?            @db.Decimal(10, 2)
  payoutPaidAt        DateTime?
  payoutReadyAt       DateTime?
  payoutStatus        PayoutStatus        @default(PENDING)
  fulfillmentStatus   FulfillmentStatus   @default(PENDING)
  passiveFranchiseeId String?
  splitFranchisee     Decimal?            @db.Decimal(10, 2)
  rewardsUsed         Decimal?            @db.Decimal(10, 2)
  items               OrderItem[]
  cliente             User?               @relation("ClienteOrders", fields: [clienteId], references: [id])
  editor              User?               @relation("EditorOrders", fields: [editorId], references: [id])
  event               Event               @relation(fields: [eventId], references: [id])
  passiveFranchisee   User?               @relation("FranchiseePassiveCommissions", fields: [passiveFranchiseeId], references: [id])

  @@map("orders")
}

model PhotoLike {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  photoUrl  String
  createdAt DateTime @default(now())
  expiresAt DateTime
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId, photoUrl])
  @@map("photo_likes")
}

model ServiceCatalog {
  id               String                @id @default(cuid())
  name             String
  description      String?
  basePrice        Decimal               @db.Decimal(10, 2)
  estimatedMinutes Int                   @default(60)
  active           Boolean               @default(true)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  category         String                @default("FOTOGRAFIA")
  proServices      ProfessionalService[]

  @@map("service_catalog")
}

model ProfessionalService {
  id             String          @id @default(cuid())
  profissionalId String
  name           String
  description    String?
  price          Decimal         @db.Decimal(10, 2)
  active         Boolean         @default(true)
  catalogId      String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  category       String?
  orderItems     OrderItem[]
  catalog        ServiceCatalog? @relation(fields: [catalogId], references: [id])
  profissional   Profissional    @relation(fields: [profissionalId], references: [id], onDelete: Cascade)

  @@map("professional_services")
}

model EventMedia {
  id         String      @id @default(cuid())
  eventId    String
  url        String
  shortId    String
  price      Decimal?    @db.Decimal(10, 2)
  type       String      @default("PHOTO")
  createdAt  DateTime    @default(now())
  event      Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@unique([eventId, shortId])
  @@map("event_media")
}

model OrderItem {
  id             String               @id @default(cuid())
  orderId        String
  mediaId        String?
  serviceId      String?
  price          Decimal              @db.Decimal(10, 2)
  quantity       Int                  @default(1)
  printProductId String?
  media          EventMedia?          @relation(fields: [mediaId], references: [id])
  order          Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  printProduct   PrintProduct?        @relation(fields: [printProductId], references: [id])
  service        ProfessionalService? @relation(fields: [serviceId], references: [id])

  @@map("order_items")
}

model UserPoints {
  id        String   @id @default(cuid())
  userId    String   @unique
  total     Int      @default(0)
  redeemed  Int      @default(0)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_points")
}

model PrintRedemption {
  id             String           @id @default(cuid())
  userId         String
  pointsUsed     Int
  quantity       Int
  packageType    String
  status         RedemptionStatus @default(PENDING)
  selectedPhotos String[]
  deliveryType   String
  addressJson    String?
  trackingCode   String?
  supplierId     String?
  unitCost       Decimal?         @db.Decimal(10, 2)
  shippingCost   Decimal?         @db.Decimal(10, 2)
  totalCost      Decimal?         @db.Decimal(10, 2)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  supplier       PrintSupplier?   @relation(fields: [supplierId], references: [id])
  user           User             @relation(fields: [userId], references: [id])

  @@map("print_redemptions")
}

model PrintSupplier {
  id           String            @id @default(cuid())
  name         String
  type         String
  printerModel String?
  printerCost  Decimal?          @db.Decimal(10, 2)
  costPer10x15 Decimal           @db.Decimal(10, 4)
  costPer4x6   Decimal?          @db.Decimal(10, 4)
  boxCost      Decimal?          @db.Decimal(10, 4)
  labelCost    Decimal?          @db.Decimal(10, 4)
  uberCost     Decimal?          @db.Decimal(10, 2)
  baseCep      String?
  active       Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  redemptions  PrintRedemption[]

  @@map("print_suppliers")
}

model Contest {
  id          String        @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  status      ContestStatus @default(DRAFT)
  prize1st    String
  prize2nd    String?
  prize3rd    String?
  prize1stPts Int
  prize2ndPts Int?
  prize3rdPts Int?
  createdAt   DateTime      @default(now())

  @@map("contests")
}

model PlatformConfig {
  key       String   @id
  value     String
  label     String
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("platform_configs")
}

model WeeklyPayout {
  id           String       @id @default(cuid())
  weekStart    DateTime
  weekEnd      DateTime
  status       PayoutStatus @default(PENDING)
  generatedAt  DateTime     @default(now())
  paidAt       DateTime?
  totalRevenue Decimal      @db.Decimal(10, 2)
  totalPayout  Decimal      @db.Decimal(10, 2)
  notesAdmin   String?
  items        PayoutItem[]

  @@map("weekly_payouts")
}

model PayoutItem {
  id            String       @id @default(cuid())
  payoutId      String
  recipientType String
  recipientId   String
  recipientName String
  pixKey        String?
  orderCount    Int
  grossRevenue  Decimal      @db.Decimal(10, 2)
  splitPct      Decimal      @db.Decimal(5, 2)
  amount        Decimal      @db.Decimal(10, 2)
  status        String       @default("PENDING")
  paidAt        DateTime?
  pixTxId       String?
  payout        WeeklyPayout @relation(fields: [payoutId], references: [id])

  @@map("payout_items")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  details   String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model Quote {
  id               String      @id @default(cuid())
  clientName       String
  clientEmail      String
  clientPhone      String?
  eventDate        DateTime?
  location         String?
  services         String[]
  notes            String?
  status           QuoteStatus @default(PENDING)
  convertedEventId String?
  cartorioId       String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  cartorio         Cartorio?   @relation(fields: [cartorioId], references: [id])

  @@map("quotes")
}

model PrintProduct {
  id           String              @id @default(cuid())
  category     String
  name         String
  sku          String              @unique
  supplierCost Decimal             @db.Decimal(10, 2)
  supplier     String              @default("CK")
  active       Boolean             @default(true)
  marginPct    Float               @default(30)
  sellingPrice Decimal?            @db.Decimal(10, 2)
  description  String?
  unit         String              @default("un")
  minQty       Int?
  maxQty       Int?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  maxPhotos    Int?
  orderItems   OrderItem[]
  events       EventPrintProduct[]

  @@map("print_products")
}

model EventPrintProduct {
  id             String       @id @default(cuid())
  eventId        String
  printProductId String
  customPrice    Decimal?     @db.Decimal(10, 2)
  active         Boolean      @default(true)
  event          Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  product        PrintProduct @relation(fields: [printProductId], references: [id], onDelete: Cascade)

  @@unique([eventId, printProductId])
  @@map("event_print_products")
}

model UserCalendarCredential {
  id           String   @id @default(cuid())
  userId       String   @unique
  provider     String   @default("google")
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  calendarId   String   @default("primary")
  scope        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_calendar_credentials")
}

model CalendarSlot {
  id            String     @id @default(cuid())
  userId        String
  startAt       DateTime
  endAt         DateTime
  status        SlotStatus @default(BLOCKED)
  source        SlotSource @default(MANUAL)
  eventId       String?
  googleEventId String?
  title         String?
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  event         Event?     @relation(fields: [eventId], references: [id])
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startAt, endAt])
  @@map("calendar_slots")
}

model FranchiseProfile {
  id                      String              @id @default(cuid())
  userId                  String              @unique
  printCredits            Int                 @default(0)
  active                  Boolean             @default(true)
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  inventoryAlertThreshold Int                 @default(50)
  lastSupplyOrderAt       DateTime?
  tier                    FranchiseTier       @default(BRONZE)
  approvedSalesVolume     Int                 @default(0)
  hideFromBooking         Boolean             @default(false)
  printServices           Json?               @default("[]")
  transactions            CreditTransaction[]
  events                  Event[]
  user                    User                @relation(fields: [userId], references: [id])
  prints                  PhygitalPrint[]

  @@map("franchise_profiles")
}

model CreditTransaction {
  id          String           @id @default(cuid())
  profileId   String
  amount      Int
  type        String
  description String?
  referenceId String?
  createdAt   DateTime         @default(now())
  profile     FranchiseProfile @relation(fields: [profileId], references: [id])

  @@map("credit_transactions")
}

enum Role {
  ADMIN
  CARTORIO
  PROFISSIONAL
  CLIENTE
  FRANCHISEE
}

enum PrintStatus {
  PENDING_PRINT
  PRINTED
  DISPATCHED_MAIL
}

enum AcceptanceStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum QuoteStatus {
  PENDING
  APPROVED
  REJECTED
  CONVERTED
  PRICED
}

enum RedemptionStatus {
  PENDING
  APROVADO
  PRINTING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum ContestStatus {
  DRAFT
  ACTIVE
  FINISHED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  CANCELLED
  AVAILABLE
}

enum EventType {
  ALBUM_FULL
  PHOTO_MARKETPLACE
  FOTO_POINT
  FLASH_EVENT
}

enum SlotStatus {
  BLOCKED
  CONFIRMED
  CANCELLED
}

enum SlotSource {
  MANUAL
  BOOKING
  GOOGLE_SYNC
}

enum DeliveryType {
  LOCAL_PICKUP
  SHIPPING
  DIGITAL_ONLY
}

enum PaymentModel {
  PRE_PAID
  POST_PAID
}

enum OrderPaymentMethod {
  CREDIT_CARD
  PIX
  CASH
  MANUAL
  FREE
}

enum FranchiseTier {
  BRONZE
  SILVER
  GOLD
  DIAMOND
}

enum FulfillmentStatus {
  PENDING
  LOCAL_QUEUE
  LAB_PROCESSING
  SHIPPED
  DELIVERED
}

model SharedAlbum {
  id          String   @id @default(cuid())
  nome        String
  slug        String   @unique
  folderId    String?  @unique // Google Drive Folder ID
  goalPoses   Int      @default(36)
  status      String   @default("OPEN")
  cycleEndDay Int?     @default(30)
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner        User               @relation("OwnedAlbums", fields: [ownerId], references: [id])
  members      AlbumMember[]
  media        SharedAlbumMedia[]
  accessLinks  AccessLink[]
  subscription Subscription?

  @@map("shared_albums")
}

model AlbumMember {
  id        String   @id @default(cuid())
  albumId   String
  userId    String
  role      String   @default("COLLABORATOR") // OWNER, COLLABORATOR, SPECTATOR
  createdAt DateTime @default(now())

  album SharedAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([albumId, userId])
  @@map("album_members")
}

model SharedAlbumMedia {
  id            String   @id @default(cuid())
  albumId       String
  fileId        String   @unique // Google Drive File ID
  webViewLink   String
  thumbnailLink String?
  uploadedById  String
  createdAt     DateTime @default(now())

  album      SharedAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
  uploadedBy User        @relation(fields: [uploadedById], references: [id])
  votes      MediaVote[]

  @@map("shared_album_media")
}

model MediaVote {
  id      String @id @default(cuid())
  mediaId String
  userId  String

  media SharedAlbumMedia @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([mediaId, userId])
  @@map("media_votes")
}

model AccessLink {
  id        String    @id @default(cuid())
  albumId   String
  code      String    @unique
  type      String    @default("TEMPORARY") // PERMANENT, TEMPORARY
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  album SharedAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@map("access_links")
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  PENDING
}

model Subscription {
  id              String             @id @default(cuid())
  userId          String
  albumId         String             @unique
  status          SubscriptionStatus @default(PENDING)
  planLimit       Int                @default(36)
  gatewaySubId    String?
  nextBillingDate DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user  User        @relation(fields: [userId], references: [id])
  album SharedAlbum @relation(fields: [albumId], references: [id])

  @@map("subscriptions")
}
