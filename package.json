{
  "name": "foto-segundo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "npx concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "npx prisma generate && npm run build --prefix frontend",
    "vercel-build": "npx prisma generate && npm run build --prefix frontend",
    "start": "node api/index.js",
    "postinstall": "npx prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "mercadopago": "^2.12.0",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5"
  }
}
